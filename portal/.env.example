# Copy to .env (gitignored) and paste your token from `claude setup-token`.
# Without it the chat falls back to the Claude Code CLI's own login on this Mac.
CLAUDE_CODE_OAUTH_TOKEN=paste-your-sk-ant-oat-token-here

# Optional overrides
