# JOBS_DIR=/Users/Berzins/Desktop/Linards current/Linards jobs folder

# Figma parity read (tooling/figma/figma-parity.mjs — standalone, never in build.mjs)
# FIGMA_TOKEN=paste-your-figma-personal-access-token
# FIGMA_FILE_KEY=paste-the-file-key-from-the-figma-url
