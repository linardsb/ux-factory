    },
    "type-ramp": {
      "$description": "Type ramp — generic modular scale",
      "type-display": { "$value": "clamp(40px, 6vw, 76px)",   "$type": "dimension" },
      "type-h1":      { "$value": "clamp(32px, 4vw, 56px)",   "$type": "dimension" },
      "type-h2":      { "$value": "clamp(24px, 2.5vw, 34px)", "$type": "dimension" },
      "type-h3":      { "$value": "20px",                     "$type": "dimension" },
      "type-lead":    { "$value": "clamp(18px, 1.5vw, 22px)", "$type": "dimension" },
      "type-body":    { "$value": "16px",                     "$type": "dimension" },
      "type-caption": { "$value": "13px",                     "$type": "dimension" },
      "type-eyebrow": { "$value": "12px",                     "$type": "dimension" }
