{
  "$description": "ux-factory design tokens (DTCG, widely-implemented string profile). Single source of truth — system/tokens.contract.css and system/tokens.neutral.css are GENERATED from this file by agent-layer/gen-token-css.mjs. `contract` = the brand-agnostic semantic slots every component references, with neutral literal fallbacks (no brand ever). `neutral` = the factory's no-brand pack: primitives plus the semantic map binding contract tokens to them. A company pack starts as a clone of the neutral group with its own primitives.",
  "contract": {
    "$description": "Layer 1 — semantic token CONTRACT (brand-agnostic). Every semantic token components may use, with neutral fallbacks. Literals only: the contract must stand alone with no pack loaded.",
    "fg-surface": {
      "$description": "Colour: foreground / surface (light context)",
      "color-fg":            { "$value": "#1a1a1a", "$type": "color" },
      "color-fg-muted":      { "$value": "#6b7280", "$type": "color" },
      "color-bg":            { "$value": "#ffffff", "$type": "color" },
      "color-bg-surface":    { "$value": "#f4f4f5", "$type": "color" },
      "color-border":        { "$value": "#d4d4d8", "$type": "color" },
      "color-border-strong": { "$value": "#1a1a1a", "$type": "color" },
      "color-white":         { "$value": "#ffffff", "$type": "color" }
    },
    "accent": {
      "$description": "Colour: accent",
      "color-accent":           { "$value": "#2563eb", "$type": "color" },
      "color-accent-hover":     { "$value": "#1d4ed8", "$type": "color" },
      "color-accent-active":    { "$value": "#1e40af", "$type": "color" },
      "color-accent-fg":        { "$value": "#ffffff", "$type": "color" },
      "color-accent-secondary": { "$value": "#64748b", "$type": "color" },
      "color-accent-on-inverse": { "$value": "#3d7bff", "$type": "color" },
      "color-accent-wash":      { "$value": "color-mix(in srgb, var(--color-accent) 5%, transparent)", "$type": "color", "$description": "atmosphere — the accent as a barely-there ground wash (hero glow); packs may retune or null it" }
    },
    "inverse": {
      "$description": "Colour: inverse (content on a dark surface)",
      "color-bg-inverse":           { "$value": "#1a1a1a", "$type": "color" },
      "color-fg-on-inverse":        { "$value": "#f4f4f5", "$type": "color" },
      "color-fg-on-inverse-strong": { "$value": "#ffffff", "$type": "color" },
      "color-fg-on-inverse-muted":  { "$value": "color-mix(in srgb, var(--color-fg-on-inverse) 50%, transparent)", "$type": "color" },
      "color-fg-on-inverse-soft":   { "$value": "color-mix(in srgb, var(--color-fg-on-inverse) 82%, transparent)", "$type": "color" },
      "color-inverse-line":         { "$value": "color-mix(in srgb, var(--color-fg-on-inverse) 12%, transparent)", "$type": "color" },
      "color-inverse-wash":         { "$value": "color-mix(in srgb, var(--color-fg-on-inverse) 6%, transparent)", "$type": "color" },
      "color-on-dark-border":       { "$value": "color-mix(in srgb, var(--color-white) 50%, transparent)", "$type": "color" }
    },
    "fonts": {
      "$description": "Fonts (neutral system stack; a pack picks real faces)",
      "font-display": { "$value": ["ui-sans-serif", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"], "$type": "fontFamily" },
      "font-body":    { "$value": ["ui-sans-serif", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"], "$type": "fontFamily" },
      "font-mono":    { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$type": "fontFamily", "$description": "technical stamp — numerals, code, machine-adjacent text" }
    },
    "spacing": {
      "$description": "Spacing (generic 4px scale)",
      "spacing-xs":  { "$value": "4px",  "$type": "dimension" },
      "spacing-sm":  { "$value": "8px",  "$type": "dimension" },
      "spacing-md":  { "$value": "16px", "$type": "dimension" },
      "spacing-lg":  { "$value": "24px", "$type": "dimension" },
      "spacing-xl":  { "$value": "32px", "$type": "dimension" },
      "spacing-2xl": { "$value": "48px", "$type": "dimension" },
      "spacing-3xl": { "$value": "64px", "$type": "dimension" },
      "spacing-4xl": { "$value": "96px", "$type": "dimension" }
    },
    "radius": {
      "$description": "Radius (non-zero default: radius is a brand choice, not a base rule)",
      "radius-sm": { "$value": "4px",  "$type": "dimension" },
      "radius-md": { "$value": "8px",  "$type": "dimension" },
      "radius-lg": { "$value": "16px", "$type": "dimension" }
    },
    "shadows": {
      "$description": "Shadows (neutral, black-tinted)",
      "shadow-sm": { "$value": "0 1px 2px rgba(0, 0, 0, 0.06)",   "$type": "shadow" },
      "shadow-md": { "$value": "0 4px 6px rgba(0, 0, 0, 0.08)",   "$type": "shadow" },
      "shadow-lg": { "$value": "0 10px 15px rgba(0, 0, 0, 0.10)", "$type": "shadow" }
    },
    "motion": {
      "$description": "Motion: durations + easings — how the system moves; a pack retunes pace and character like any other token",
      "motion-fast":        { "$value": "160ms", "$type": "duration", "$description": "micro feedback — hovers, color/opacity" },
      "motion-base":        { "$value": "200ms", "$type": "duration", "$description": "structural — lifts, slides, panels, page crossfade" },
      "motion-ambient":     { "$value": "3s",    "$type": "duration", "$description": "idle pulses (the hero pill)" },
      "motion-ease":        { "$value": "ease",  "$type": "easing",   "$description": "default curve" },
      "motion-slow":        { "$value": "480ms", "$type": "duration", "$description": "entrances + reveals — hero cascade, underline draw, section labels" },
      "motion-stagger":     { "$value": "70ms",  "$type": "duration", "$description": "step between staggered children (compose delays with calc)" },
      "motion-rise":        { "$value": "20px",  "$type": "dimension","$description": "reveal translate offset — how far elements travel in" },
      "motion-ease-spring": { "$value": "linear(0, 0.004, 0.016, 0.035, 0.062, 0.096, 0.138, 0.187, 0.242, 0.304, 0.371, 0.443, 0.519, 0.598, 0.68, 0.763, 0.846, 0.918, 0.973, 1.007, 1.019, 1.016, 1.007, 1.001, 1)", "$type": "easing", "$description": "baked spring — subtle single overshoot (~1.9%) for emphasis" }
    },
    "layout": {
      "$description": "Layout",
