      "color-cloud":    { "$value": "#f4f4f5", "$type": "color", "$description": "light surface" },
      "color-line":     { "$value": "#d4d4d8", "$type": "color", "$description": "border grey" },
      "color-white":    { "$value": "#ffffff", "$type": "color" }
