      "color-fg":            { "$value": "{neutral.primitives.color-ink}",   "$type": "color", "$description": "primary text" },
      "color-fg-muted":      { "$value": "{neutral.primitives.color-slate}", "$type": "color", "$description": "labels, captions, secondary text" },
