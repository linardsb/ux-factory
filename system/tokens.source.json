      "font-body":    { "$value": ["ui-sans-serif", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"], "$type": "fontFamily" },
      "font-mono":    { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$type": "fontFamily", "$description": "technical stamp — numerals, code, machine-adjacent text" }
    },
    "spacing": {
      "$description": "Spacing scale (8 steps, 4px base)",
      "spacing-xs":  { "$value": "4px",  "$type": "dimension" },
