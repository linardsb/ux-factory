    "primitives": {
      "$description": "1. PRIMITIVES — neutral palette (raw values, no brand)",
      "color-ink":      { "$value": "#1a1a1a", "$type": "color", "$description": "near-black — content base" },
      "color-slate":    { "$value": "#6b7280", "$type": "color", "$description": "mid grey — secondary text" },
      "color-blue":     { "$value": "#2563eb", "$type": "color", "$description": "plain accent blue — signal" },
