      "type-h3":      { "$value": "20px",                     "$type": "dimension" },
      "type-lead":    { "$value": "clamp(18px, 1.5vw, 22px)", "$type": "dimension" },
      "type-body":    { "$value": "16px",                     "$type": "dimension" },
      "type-caption": { "$value": "13px",                     "$type": "dimension" },
      "type-eyebrow": { "$value": "12px",                     "$type": "dimension" }
    }
  },
  "neutral": {
